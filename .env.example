# Copy this file to .env and fill in values. Never commit .env.

# LangSmith (for loading runs + writing feedback)
LANGSMITH_API_KEY=

# LLM judge (optional — deterministic rules work without it)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

